{
  "version": 2,
  "public": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/(.*)\\.(css|js|jpg|jpeg|png|gif|svg|ico|woff|woff2|ttf|eot)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/pages/organizations",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/schedule-demo",
      "destination": "/demo.html",
      "permanent": false
    },
    {
      "source": "/collections/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/pages/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/blogs/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/cart",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/account/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/checkouts/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/orders/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/policies/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/search",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/variants/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/apps/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/discount/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/password",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/gift_cards/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/tools/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/products/ampd",
      "destination": "/products/core",
      "permanent": true
    },
    {
      "source": "/platform.html",
      "destination": "/products/core",
      "permanent": true
    },
    {
      "source": "/contact",
      "destination": "/demo.html",
      "permanent": false
    },
    {
      "source": "/contact.html",
      "destination": "/demo.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/whats-next",
      "destination": "/whats-next.html"
    },
    {
      "source": "/why-ampd",
      "destination": "/why-ampd.html"
    },
    {
      "source": "/safety",
      "destination": "/safety.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy-policy.html"
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy-policy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/terms-of-service",
      "destination": "/terms.html"
    },
    {
      "source": "/((?!about\\.html|mission\\.html|platform\\.html|safety\\.html|safety|request-pilot\\.html|privacy-policy\\.html|privacy-policy|privacy|terms\\.html|terms-of-service|terms|why-ampd\\.html|whats-next\\.html|demo\\.html|schedule-demo|whats-next|why-ampd|products/|api/).*)",
      "destination": "/index.html"
    }
  ]
}